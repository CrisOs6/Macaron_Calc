<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="10dp"
        android:layout_marginHorizontal="20dp"
        android:textColor="@color/linea"
        android:background="@drawable/pantalla_salida"
        android:gravity="end|center_vertical"
        android:text="0"
        android:paddingEnd="25dp"
        android:layout_weight="1.5"
        android:textSize="26sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:layout_weight="1.3"
        android:layout_marginHorizontal="15dp"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnUno"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="1"
                    android:textColor="@color/linea"
                    android:textSize="24sp"
                    android:layout_marginVertical="10dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/number_button" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDos"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="2"
                    android:textColor="@color/linea"
                    android:textSize="24sp"
                    android:layout_marginHorizontal="2dp"
                    android:layout_marginVertical="10dp"
                    android:background="@drawable/number_button" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnTres"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="3"
                    android:textColor="@color/linea"
                    android:textSize="24sp"
                    android:layout_marginVertical="10dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/number_button" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCuatro"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="4"
                    android:textColor="@color/linea"
                    android:textSize="24sp"
                    android:layout_marginVertical="10dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/number_button" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCinco"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="5"
                    android:textColor="@color/linea"
                    android:textSize="24sp"
                    android:layout_marginVertical="10dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/number_button" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSeis"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="6"
                    android:textColor="@color/linea"
                    android:textSize="24sp"
                    android:layout_marginVertical="10dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/number_button" />
            </LinearLayout>

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDiv"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:text="/"
            android:textColor="@color/linea"
            android:textSize="50sp"
            android:layout_marginVertical="5dp"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/opera_button" />


    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:layout_weight="1"
        android:layout_marginHorizontal="15dp"
        android:layout_marginBottom="60dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSiete"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="2dp"
                    android:layout_marginVertical="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/number_button"
                    android:text="7"
                    android:textColor="@color/linea"
                    android:textSize="24sp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnOcho"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="8"
                    android:textColor="@color/linea"
                    android:textSize="24sp"
                    android:layout_marginVertical="5dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/number_button" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnNueve"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="9"
                    android:textColor="@color/linea"
                    android:textSize="24sp"
                    android:layout_marginVertical="5dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/number_button" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal">
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCero"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="0"
                    android:textColor="@color/linea"
                    android:textSize="24sp"
                    android:layout_marginVertical="5dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/number_button" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnMenos"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="-"
                    android:textColor="@color/linea"
                    android:textSize="60sp"
                    android:layout_marginVertical="5dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/opera_button" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnMult"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="x"
                    android:textColor="@color/linea"
                    android:textSize="40sp"
                    android:layout_marginVertical="5dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/opera_button" />
            </LinearLayout>
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSuma"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="+"
                android:textColor="@color/linea"
                android:textSize="40sp"
                android:layout_marginVertical="5dp"
                android:layout_marginHorizontal="2dp"
                android:background="@drawable/opera_button" />

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnEqual"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:text="="
            android:textColor="@color/linea"
            android:textSize="50sp"
            android:layout_marginVertical="5dp"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/result_button" />

    </LinearLayout>

</LinearLayout>
